<mxfile>
  <diagram name="Your System - RLAIF" id="rlaif-system">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Your System: LLM-as-Judge Query Evolution&lt;/b&gt;&lt;br&gt;Llama 3.2 3B learns to write queries • Llama 70B judges quality • Retrieval metrics validate" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="900" height="50" as="geometry"/>
        </mxCell>

        <!-- Inspired by -->
        <mxCell id="inspired" value="Inspired by &lt;a href='https://arxiv.org/abs/2503.00223'&gt;DeepRetrieval (Jiang et al., 2025)&lt;/a&gt; — adapted from Qwen 3B + PPO on PubMed to Llama 3.2 3B + RLAIF on product search" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="230" y="55" width="780" height="30" as="geometry"/>
        </mxCell>

        <!-- Input: Anchor Item -->
        <mxCell id="anchor" value="&lt;b&gt;Anchor Item&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;i&gt;&quot;iPhone 15 Pro&lt;br&gt;128GB Space Black&quot;&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- Student Model -->
        <mxCell id="student_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="350" y="100" width="250" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="student_title" value="&lt;b&gt;STUDENT MODEL&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#7B1FA2;" vertex="1" parent="1">
          <mxGeometry x="400" y="108" width="150" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="student_model" value="&lt;b&gt;Llama 3.2 3B&lt;/b&gt;&lt;br&gt;Fine-tuned policy π_θ&lt;br&gt;&lt;br&gt;Input: item metadata&lt;br&gt;Output: semantic query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="375" y="140" width="200" height="90" as="geometry"/>
        </mxCell>

        <!-- Generated Query -->
        <mxCell id="gen_query" value="&lt;b&gt;Generated Query&lt;/b&gt;&lt;br&gt;&lt;i&gt;&quot;premium wireless charger&lt;br&gt;MagSafe compatible fast&lt;br&gt;charging stand iPhone&quot;&lt;/i&gt;" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=0.15;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="210" height="110" as="geometry"/>
        </mxCell>

        <!-- Arrow anchor to student -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="anchor" target="student_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Arrow student to query -->
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="student_box" target="gen_query" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- TWO REWARD PATHS -->
        <mxCell id="path_label" value="&lt;b&gt;TWO REWARD SIGNALS&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="470" y="280" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Path 1: Retrieval Metrics -->
        <mxCell id="retrieval_path" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#388E3C;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="400" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="ret_title" value="&lt;b&gt;Signal 1: Hard Retrieval Metrics&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="130" y="330" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ret_system" value="&lt;b&gt;Two-Tower Retrieval&lt;/b&gt;&lt;br&gt;+ FAISS Index&lt;br&gt;&lt;br&gt;Query → top-K items" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="110" y="370" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="ret_metrics" value="&lt;b&gt;Compute:&lt;/b&gt;&lt;br&gt;• Recall @ K&lt;br&gt;• Precision @ K&lt;br&gt;• Relevance overlap&lt;br&gt;with ground truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="370" width="160" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ret_score" value="&lt;b&gt;R_retrieval = 0.72&lt;/b&gt;&lt;br&gt;(tiered: ≥0.7 → +5.0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="180" y="500" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a_ret1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="ret_system" target="ret_metrics" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a_ret2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="ret_metrics" target="ret_score" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Path 2: LLM Judge -->
        <mxCell id="judge_path" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="540" y="320" width="430" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="judge_title" value="&lt;b&gt;Signal 2: LLM-as-Judge (RLAIF)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="610" y="330" width="290" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="judge_model" value="&lt;b&gt;Llama 70B&lt;/b&gt;&lt;br&gt;(frozen judge)&lt;br&gt;&lt;br&gt;Evaluates:&lt;br&gt;• Semantic relevance&lt;br&gt;• Intent alignment&lt;br&gt;• Query specificity&lt;br&gt;• Coverage breadth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="370" width="170" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="judge_output" value="&lt;b&gt;Scores 1-5 per&lt;br&gt;dimension&lt;/b&gt;&lt;br&gt;&lt;br&gt;+ rationale text&lt;br&gt;(for debugging)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="370" width="160" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="judge_score" value="&lt;b&gt;R_judge = 0.81&lt;/b&gt;&lt;br&gt;(normalized 0-1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90CAF9;strokeColor=#1565C0;fontSize=12;fontColor=#0D47A1;" vertex="1" parent="1">
          <mxGeometry x="680" y="510" width="180" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="a_j1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="judge_model" target="judge_output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a_j2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="judge_output" target="judge_score" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow from query to both paths -->
        <mxCell id="a_path1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="gen_query" target="ret_system" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="805" y="270"/>
              <mxPoint x="190" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a_path2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="gen_query" target="judge_model" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="805" y="270"/>
              <mxPoint x="655" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Combined Reward -->
        <mxCell id="combined" value="&lt;b&gt;Combined Reward&lt;/b&gt;&lt;br&gt;&lt;br&gt;R = α · R_retrieval + (1−α) · R_judge&lt;br&gt;&lt;br&gt;&lt;i&gt;Hard metrics prevent reward hacking.&lt;br&gt;Judge captures semantic quality metrics miss.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=3;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="640" width="350" height="120" as="geometry"/>
        </mxCell>

        <!-- Arrows to combined -->
        <mxCell id="a_c1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="ret_score" target="combined" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a_c2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="judge_score" target="combined" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Update step -->
        <mxCell id="update" value="&lt;b&gt;PPO / GRPO Update&lt;/b&gt;&lt;br&gt;Update Llama 3.2 3B weights" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;strokeWidth=2;fontSize=12;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="810" width="350" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_up" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="combined" target="update" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Loop back -->
        <mxCell id="a_loop" value="Next epoch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;dashed=1;dashPattern=8 4;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" source="update" target="student_box" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="40" y="835"/>
              <mxPoint x="40" y="250"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Why dual signal callout -->
        <mxCell id="why_dual" value="&lt;b&gt;Why dual signal?&lt;/b&gt;&lt;br&gt;Judge alone → model exploits judge biases (reward hacking)&lt;br&gt;Retrieval alone → misses semantic quality (grammatical but irrelevant)&lt;br&gt;Both together → grounded + nuanced" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;fontSize=11;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="740" y="660" width="370" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
